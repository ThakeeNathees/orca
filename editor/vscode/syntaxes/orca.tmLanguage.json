{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Orca",
  "scopeName": "source.orca",
  "patterns": [
    { "include": "#comment" },
    { "include": "#annotation" },
    { "include": "#block-definition" },
    { "include": "#expressions" }
  ],
  "repository": {
    "comment": {
      "match": "//.*$",
      "name": "comment.line.double-slash.orca"
    },
    "annotation": {
      "patterns": [
        {
          "begin": "(@)([a-zA-Z_][a-zA-Z0-9_]*)(\\()",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.annotation.orca" },
            "2": { "name": "entity.name.function.annotation.orca" },
            "3": { "name": "punctuation.brackets.round.orca" }
          },
          "end": "\\)",
          "endCaptures": {
            "0": { "name": "punctuation.brackets.round.orca" }
          },
          "patterns": [
            { "include": "#string" },
            { "include": "#number" },
            { "include": "#boolean" },
            {
              "match": ",",
              "name": "punctuation.separator.comma.orca"
            }
          ]
        },
        {
          "match": "(@)([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "punctuation.definition.annotation.orca" },
            "2": { "name": "entity.name.function.annotation.orca" }
          }
        }
      ]
    },
    "block-definition": {
      "match": "\\b(model|agent|tool|knowledge|workflow|cron|webhook|schema|input|let)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.other.block-type.orca" },
        "2": { "name": "entity.name.type.orca" }
      }
    },
    "expressions": {
      "patterns": [
        { "include": "#comment" },
        { "include": "#annotation" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#null" },
        { "include": "#assignment-key" },
        { "include": "#arrow-operator" },
        { "include": "#pipe-operator" },
        { "include": "#operator" },
        { "include": "#delimiter" },
        { "include": "#type-annotation" },
        { "include": "#keyword" },
        { "include": "#identifier" }
      ]
    },
    "string": {
      "patterns": [
        { "include": "#raw-string" },
        { "include": "#quoted-string" }
      ]
    },
    "raw-string": {
      "patterns": [
        { "include": "#raw-string-python" },
        { "include": "#raw-string-markdown" },
        { "include": "#raw-string-json" },
        { "include": "#raw-string-yaml" },
        { "include": "#raw-string-plain" }
      ]
    },
    "raw-string-python": {
      "begin": "(```)(py|python)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.orca" },
        "2": { "name": "entity.name.tag.language.orca" }
      },
      "end": "^\\s*```",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.orca" }
      },
      "name": "string.unquoted.raw.orca",
      "contentName": "meta.embedded.block.python",
      "patterns": [
        { "include": "source.python" }
      ]
    },
    "raw-string-markdown": {
      "begin": "(```)(md|markdown)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.orca" },
        "2": { "name": "entity.name.tag.language.orca" }
      },
      "end": "^\\s*```",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.orca" }
      },
      "name": "string.unquoted.raw.orca",
      "contentName": "meta.embedded.block.markdown",
      "patterns": [
        { "include": "text.html.markdown" }
      ]
    },
    "raw-string-json": {
      "begin": "(```)(json)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.orca" },
        "2": { "name": "entity.name.tag.language.orca" }
      },
      "end": "^\\s*```",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.orca" }
      },
      "name": "string.unquoted.raw.orca",
      "contentName": "meta.embedded.block.json",
      "patterns": [
        { "include": "source.json" }
      ]
    },
    "raw-string-yaml": {
      "begin": "(```)(yaml|yml)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.orca" },
        "2": { "name": "entity.name.tag.language.orca" }
      },
      "end": "^\\s*```",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.orca" }
      },
      "name": "string.unquoted.raw.orca",
      "contentName": "meta.embedded.block.yaml",
      "patterns": [
        { "include": "source.yaml" }
      ]
    },
    "raw-string-plain": {
      "begin": "(```)(\\w*)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.orca" },
        "2": { "name": "entity.name.tag.language.orca" }
      },
      "end": "^\\s*```",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.orca" }
      },
      "name": "string.unquoted.raw.orca"
    },
    "quoted-string": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.orca",
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.orca"
        }
      ]
    },
    "number": {
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
      "name": "constant.numeric.orca"
    },
    "boolean": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.orca"
    },
    "null": {
      "match": "\\b(null)\\b",
      "name": "constant.language.null.orca"
    },
    "assignment-key": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?==)",
      "captures": {
        "1": { "name": "variable.other.property.orca" }
      }
    },
    "arrow-operator": {
      "match": "->",
      "name": "keyword.operator.arrow.orca"
    },
    "pipe-operator": {
      "match": "\\|",
      "name": "keyword.operator.pipe.orca"
    },
    "operator": {
      "match": "[=+\\-*/.]",
      "name": "keyword.operator.orca"
    },
    "delimiter": {
      "match": "[{}\\[\\](),:]",
      "name": "punctuation.orca"
    },
    "type-annotation": {
      "match": "\\b(str|int|float|bool|list|map|any)\\b",
      "name": "support.type.orca"
    },
    "keyword": {
      "match": "\\b(model|agent|tool|knowledge|workflow|cron|webhook|schema|input|let)\\b",
      "name": "keyword.other.block-type.orca"
    },
    "identifier": {
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
      "name": "variable.other.orca"
    }
  }
}
