{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Orca",
  "scopeName": "source.orca",
  "patterns": [
    { "include": "#comment" },
    { "include": "#block-definition" },
    { "include": "#expressions" }
  ],
  "repository": {
    "comment": {
      "match": "//.*$",
      "name": "comment.line.double-slash.orca"
    },
    "block-definition": {
      "match": "\\b(model|agent|tool|task|knowledge|workflow|trigger|schema)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.other.block-type.orca" },
        "2": { "name": "entity.name.type.orca" }
      }
    },
    "expressions": {
      "patterns": [
        { "include": "#comment" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#arrow-operator" },
        { "include": "#pipe-operator" },
        { "include": "#operator" },
        { "include": "#delimiter" },
        { "include": "#type-annotation" },
        { "include": "#keyword" },
        { "include": "#identifier" }
      ]
    },
    "string": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.orca",
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.orca"
        }
      ]
    },
    "number": {
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
      "name": "constant.numeric.orca"
    },
    "boolean": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.orca"
    },
    "arrow-operator": {
      "match": "->",
      "name": "keyword.operator.arrow.orca"
    },
    "pipe-operator": {
      "match": "\\|",
      "name": "keyword.operator.pipe.orca"
    },
    "operator": {
      "match": "[=+\\-*/.]",
      "name": "keyword.operator.orca"
    },
    "delimiter": {
      "match": "[{}\\[\\],]",
      "name": "punctuation.orca"
    },
    "type-annotation": {
      "match": "\\b(str|int|float|bool|list|map|any)\\b",
      "name": "support.type.orca"
    },
    "keyword": {
      "match": "\\b(model|agent|tool|task|knowledge|workflow|trigger|schema)\\b",
      "name": "keyword.other.block-type.orca"
    },
    "identifier": {
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
      "name": "variable.other.orca"
    }
  }
}
