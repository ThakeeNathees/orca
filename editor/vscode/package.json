{
  "name": "orca",
  "displayName": "Orca",
  "description": "Orca declarative AI agent language",
  "version": "0.1.0",
  "publisher": "orca",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:orca"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "orca",
        "aliases": [
          "Orca",
          "orca"
        ],
        "extensions": [
          ".orca"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "orca",
        "scopeName": "source.orca",
        "path": "./syntaxes/orca.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.python": "python",
          "meta.embedded.block.markdown": "markdown",
          "meta.embedded.block.json": "json",
          "meta.embedded.block.yaml": "yaml"
        }
      }
    ],
    "snippets": [
      {
        "language": "orca",
        "path": "./snippets/orca.json"
      }
    ],
    "commands": [
      {
        "command": "orca.restartLsp",
        "title": "Orca: Restart Language Server"
      }
    ],
    "configuration": {
      "title": "Orca",
      "properties": {
        "orca.lsp.path": {
          "type": "string",
          "default": "orca",
          "description": "Path to the orca binary used for the language server."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -watch -p ."
  }
}
