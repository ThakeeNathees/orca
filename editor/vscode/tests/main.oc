
model gpt4o {
    model_name = "gpt-4o"
    api_key = "sk-proj-1234567890"
}

agent Researcher  {
    model = gpt4o
}

// Schema block with type annotations
schema model {
    provider    = {type: str, required: true}
    model_name  = {type: str | model, required: false}
    temperature = {type: float, required: false}
}

schema agent {
    model  = {type: str | model, required: true}
    tools  = {type: list, required: false}
    prompt = {type: str, required: true}
}
