// Multiple blocks in a single file — a model and two agents.

model gpt4 {
  provider    = "openai"
  version     = "gpt-4o"
  temperature = 0.2
}

// The researcher uses web search tools.
agent researcher {
  model  = gpt4
  tools  = [web_search]
  prompt = "You research topics thoroughly."
}

// The writer takes research and produces reports.
agent writer {
  model  = gpt4
  prompt = "You are a technical writer."
}
