
// +------------+
// | Schema     | <-+
// +------------+   | (schema is the schema of the schema itself)
//    ^   |_________|
//    |
//    | (Any `schema foo {}`'s schema is `schema schema {}`)
// +-------------------+      +------------------+
// | Schema Definition | <--- | Block Definition |
// +-------------------+      +------------------+
//                          (all `foo bar {}`'s schema are `schema foo {}`)
//
@suppress("duplicate-block")
@strict_check
schema schema {}

@suppress("duplicate-block")
@strict_check
schema nulltype {}

@suppress("duplicate-block")
nulltype null {}

@suppress("duplicate-block")
@strict_check
schema bool {}

@suppress("duplicate-block")
bool true {}

@suppress("duplicate-block")
bool false {}

@suppress("duplicate-block")
@strict_check
schema string {}

@suppress("duplicate-block")
@strict_check
schema number {}

@suppress("duplicate-block")
@strict_check
schema list {}

@suppress("duplicate-block")
@strict_check
schema map {}

@suppress("duplicate-block")
@strict_check
schema callable {}

@suppress("duplicate-block")
@strict_check
schema annotated {}

@suppress("duplicate-block")
@strict_check
schema any {}

@suppress("duplicate-block")
@strict_check
schema workflow {
  @desc("The name of the workflow.")
  name = string | nulltype

  @desc("The description of the workflow.")
  desc = string | nulltype

  @desc(```
  The nodes in this workflow. This map is optional as all the nodes are
  implicitly added to the workflow.

    example:
    workflow wf {
      node_1 -> node_2
    }

  is equivalent to:
    workflow wf {
      nodes = {
        "node_1": node_1,
        "node_2": node_2,
      }
      node_1 -> node_2
    }

  However in some cases you may need to have duplicate nodes (i.e. same node
  reference by two different node in the graph) or the node name has to be
  overridden. In such cases you can use the `nodes` field to explicitly.

  example:
    workflow wf {
      nodes = {
        "node_1": node_1,
        "node_2": node_2,
        "node_3": node_1,
      }

      // Note that node_1 is used twice in the graph.
      // So we need the above syntax to explicitly specify.
      //
      // +--------+    +--------+    +--------+
      // | node_1 | -> | node_2 | -> | node_1 |
      // +--------+    +--------+    +--------+
      //   ^                 |
      //   +-----------------+

      node_1 -> node_2 -> branch {
        route = {
          "route_1": node_1,
          "route_2": "node_3",
        }
      }
    }

  ```)
  nodes = map[string, annotated["workflow_node"]] | nulltype
}

@suppress("duplicate-block")
@strict_check
schema model {
  @desc("The LLM provider to use (e.g. openai, anthropic).")
  provider = string

  @desc("The model to use for this agent. (e.g. gpt-5.2, gemini-2.5-flash).")
  model_name = string

  @desc("The API key to use for this model.")
  api_key = string | nulltype

  @desc("The base URL to use for this model.")
  base_url = string | nulltype

  @desc("Sampling temperature between 0 and 1.")
  temperature = number | nulltype
}

@suppress("duplicate-block")
@strict_check
@workflow_node
schema tool {
  @desc("The description of the tool.")
  desc = string | nulltype

  @desc("The input schema for the tool.")
  input_schema = schema | nulltype

  @desc("The output schema for the tool.")
  output_schema = schema | nulltype

  @desc("The callable to invoke for the tool.")
  invoke = callable
}

@suppress("duplicate-block")
@strict_check
@workflow_node
schema agent {
  @desc("The model to use. Can be a reference to a model block or a string.")
  model = string | model

  @desc("The persona of the agent.")
  persona = string

  @desc("The tools to use for this agent.")
  tools = list[tool] | nulltype

  @desc("Whether to use thinking tokens for the agent.")
  thinking = bool | nulltype

  @desc("The structured output schema for this agent.")
  output_schema = schema | nulltype

  @desc("Sampling temperature override. When set, takes precedence over the model block's temperature.")
  temperature = number | nulltype
}

@suppress("duplicate-block")
@strict_check
@workflow_node
@trigger_node
schema cron {
  @desc("Cron schedule expression (e.g. \"0 9 * * 1-5\").")
  schedule = string

  @desc("IANA timezone name (e.g. \"America/New_York\"). Defaults to UTC when unset.")
  timezone = string | nulltype
}

@suppress("duplicate-block")
@strict_check
@workflow_node
@trigger_node
schema webhook {
  @desc("URL path for this webhook (e.g. \"/hooks/job\").")
  path = string

  @desc("HTTP method (e.g. \"POST\").")
  method = string | nulltype
}


@suppress("duplicate-block")
@strict_check
@workflow_node
schema branch {
  @desc(```
  The transform to apply to the input.

  Example:
  workflow wf {
    some_agent -> branch {
      transform = \(out string) -> out.lower()
      route = {
        "route_1": agent_1,   // Node block reference
        "route_2": "agent_2", // Name of the node (lookup in the workflow)
      }
    }
  }
  ```)
  transform = callable | nulltype

  @desc("The routes to take based on the input.")
  route = map[string | number | bool, annotated["workflow_node"] | string]
}

// The Type of `<expr> -> <expr>`
@suppress("duplicate-block")
@strict_check
@workflow_node
schema workflow_chain {

  @desc("The left side of the workflow chain.")
  left = annotated["workflow_node"]

  @desc("The right side of the workflow chain.")
  right = annotated["workflow_node"]
}
