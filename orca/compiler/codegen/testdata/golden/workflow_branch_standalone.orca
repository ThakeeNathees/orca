model gpt4 {
  provider   = "openai"
  model_name = "gpt-4o"
}

agent handler_a {
  model   = gpt4
  persona = "Handle case A."
}

agent handler_b {
  model   = gpt4
  persona = "Handle case B."
}

workflow pipeline {
  branch {
    transform = \(payload string) -> payload
    route = {
      "a": handler_a,
      "b": handler_b,
    }
  }
}
