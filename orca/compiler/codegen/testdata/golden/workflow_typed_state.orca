schema report {
  @desc("The report content")
  content = string
  @desc("Quality score")
  score   = number
}

model gpt4 {
  provider   = "openai"
  model_name = "gpt-4o"
}

agent researcher {
  model   = gpt4
  persona = "Research topics."
}

agent writer {
  model         = gpt4
  persona       = "Write reports."
  output_schema = report
}

workflow pipeline {
  researcher -> writer
}
