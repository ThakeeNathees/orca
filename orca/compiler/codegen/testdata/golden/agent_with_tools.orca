model gpt4 {
  provider    = "openai"
  model_name  = "gpt-4o"
  temperature = 0.5
}

tool web_search {
  invoke = \(query string) -> ""
}

tool calculator {
  invoke = \(expr string) -> ""
}

agent researcher {
  model   = gpt4
  persona = "You are a research assistant."
  tools   = [web_search, calculator]
}
