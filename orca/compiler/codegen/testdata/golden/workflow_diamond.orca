model gpt4 {
  provider   = "openai"
  model_name = "gpt-4o"
}

agent classifier {
  model   = gpt4
  persona = "You classify incoming requests."
}

agent writer {
  model   = gpt4
  persona = "You write content."
}

agent analyst {
  model   = gpt4
  persona = "You analyze data."
}

agent reviewer {
  model   = gpt4
  persona = "You review and merge results."
}

workflow diamond {
  classifier -> writer
  classifier -> analyst
  writer -> reviewer
  analyst -> reviewer
}
