model gpt4 {
  provider   = "openai"
  model_name = "gpt-4o"
}

agent classifier {
  model   = gpt4
  persona = "Return 'a' or 'b'."
}

agent handler_a {
  model   = gpt4
  persona = "Handle case A."
}

agent handler_b {
  model   = gpt4
  persona = "Handle case B."
}

workflow pipeline {
  classifier -> branch {
    route = {
      "a": handler_a,
      "b": handler_b,
    }
  }
}
