schema research_report {
  @desc("The research topic")
  topic    = str
  @desc("Key findings from research")
  findings = list[str]
  @desc("Confidence score")
  score    = float | null
}

agent researcher {
  model         = gpt4
  persona       = "Research topics."
  output_schema = research_report
}

model gpt4 {
  provider   = "openai"
  model_name = "gpt-4o"
}
