model gpt4 {
  provider   = "openai"
  model_name = "gpt-4o"
}

agent classifier {
  model   = gpt4
  persona = "Classify as 'a' or 'b'."
}

agent handler_a {
  model   = gpt4
  persona = "Handle case A."
}

agent handler_b1 {
  model   = gpt4
  persona = "Handle B sub-case 1."
}

agent handler_b2 {
  model   = gpt4
  persona = "Handle B sub-case 2."
}

workflow pipeline {
  classifier -> branch {
    transform = \(out string) -> out
    route = {
      "a": handler_a,
      "b": branch {
        transform = \(out string) -> out
        route = {
          "1": handler_b1,
          "2": handler_b2,
        }
      },
    }
  }
}
