model gpt4 {
  provider    = "openai"
  model_name  = "gpt-4o"
  temperature = 0.5
}

tool web_search {
  invoke = "langchain_community.tools.web_search.WebSearchTool"
}

tool calculator {
  invoke = "langchain_community.tools.calculator.CalculatorTool"
}

agent researcher {
  model   = gpt4
  persona = "You are a research assistant."
  tools   = [web_search, calculator]
}
