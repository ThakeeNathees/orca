model gpt4 {
  provider    = "openai"
  model_name  = "gpt-4o"
  temperature = 0.5
}

tool web_search {
  invoke = ```py
def web_search(query: str) -> str:
    return ""
```
}

tool calculator {
  invoke = ```py
def calculator(expr: str) -> str:
    return ""
```
}

agent researcher {
  model   = gpt4
  persona = "You are a research assistant."
  tools   = [web_search, calculator]
}
