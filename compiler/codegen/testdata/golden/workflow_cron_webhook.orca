model gpt4 {
  provider   = "openai"
  model_name = "gpt-4o"
}

agent researcher {
  model   = gpt4
  persona = "You research topics thoroughly."
}

agent writer {
  model   = gpt4
  persona = "You write polished articles."
}

cron daily {
  schedule = "0 9 * * *"
}

webhook hooks_in {
  path = "/hooks/in"
}

workflow pipeline {
  daily    -> researcher -> writer
  hooks_in -> researcher -> writer
}
