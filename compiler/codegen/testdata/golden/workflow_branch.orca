model gpt4 {
  provider   = "openai"
  model_name = "gpt-4o"
}

agent classifier {
  model   = gpt4
  persona = "Classify the input as 'tech' or 'business'."
}

agent tech_writer {
  model   = gpt4
  persona = "You write tech articles."
}

agent biz_writer {
  model   = gpt4
  persona = "You write business articles."
}

workflow pipeline {
  classifier -> branch {
    transform = \(out string) -> out
    route = {
      "tech": tech_writer,
      "business": biz_writer,
    }
  }
}
