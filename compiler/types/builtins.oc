// Schema definitions for all block types.
// Fields without | null are required. Fields with | null are optional.
// Use @desc("...") to add a description to a field.

// Primitive type schemas — these define the built-in types.
@suppress("duplicate-block")
schema str {}

@suppress("duplicate-block")
schema int {}

@suppress("duplicate-block")
schema float {}

@suppress("duplicate-block")
schema bool {}

@suppress("duplicate-block")
schema list {}

@suppress("duplicate-block")
schema map {}

@suppress("duplicate-block")
schema any {}

@suppress("duplicate-block")
schema null {}

@suppress("duplicate-block")
schema model {
  @desc("The LLM provider to use (e.g. openai, anthropic).")
  provider = str

  @desc("The model to use for this agent. (e.g. gpt-5.2, gemini-2.5-flash).")
  model_name = str | model

  @desc("The API key to use for this model.")
  api_key = str | null

  @desc("The base URL to use for this model.")
  base_url = str | null

  @desc("Sampling temperature between 0 and 1.")
  temperature = float | null
}

@suppress("duplicate-block")
schema agent {
  @desc("The model to use. Can be a reference to a model block or a string.")
  model = str | model

  @desc("The persona of the agent.")
  persona = str

  @desc("The tools to use for this agent.")
  tools = list[tool] | null

  @desc("The structured output schema for this agent.")
  output_schema = schema | null
}

@suppress("duplicate-block")
schema tool {
  @desc("The description of the tool.")
  desc = str | null

  @desc("The input schema for the tool.")
  input_schema = schema | null

  @desc("The output schema for the tool.")
  output_schema = schema | null

  @desc("The function to invoke for the tool. Either a dotted import path or an inline raw string.")
  invoke = str
}

@suppress("duplicate-block")
schema knowledge {
  @desc("The description of the knowledge source.")
  desc = str | null
}

@suppress("duplicate-block")
schema workflow {
  @desc("The name of the workflow.")
  name = str | null

  @desc("The description of the workflow.")
  desc = str | null
}

@suppress("duplicate-block")
schema input {
  @desc("The type of this input (e.g. str, int, or a user-defined schema).")
  type = schema

  @desc("A human-readable description of what this input is for.")
  desc = str | null

  @desc("The default value if no value is provided at runtime.")
  default = any | null

  @desc("Whether this input contains sensitive data that should be masked.")
  sensitive = bool | null
}
