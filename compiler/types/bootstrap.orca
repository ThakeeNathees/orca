// Schema definitions for all block types.

// Annotations are not limited to a predefined set of names; they can be any
// identifiers and may be passed to tools that analyze the AST.
//
// Here are the internally recognized annotations:
//   @suppress: Suppresses compiler diagnostics.
//   @desc: Adds a description to a field.
//   @workflow_node: Indicates that the block is a workflow node.
//   @trigger_node: Indicates that its a workflow trigger.
//   @only_assignments: Indicates that the block only supports assignments.

// TODO: Add an ascii diagram of how the schema works.


@suppress("duplicate-block")
@only_assignments
schema schema {}

// Primitive type schemas — these define the built-in types.
@suppress("duplicate-block")
@only_assignments
schema string {}

@suppress("duplicate-block")
@only_assignments
schema number {}

@suppress("duplicate-block")
@only_assignments
schema bool {}

@suppress("duplicate-block")
bool true {}

@suppress("duplicate-block")
bool false {}

@suppress("duplicate-block")
@only_assignments
schema list {}

@suppress("duplicate-block")
@only_assignments
schema map {}

@suppress("duplicate-block")
@only_assignments
schema callable {}

@suppress("duplicate-block")
@only_assignments
schema any {}

@suppress("duplicate-block")
@only_assignments
schema null {}

@suppress("duplicate-block")
schema workflow {
  @desc("The name of the workflow.")
  name = string | null

  @desc("The description of the workflow.")
  desc = string | null
}

@suppress("duplicate-block")
@only_assignments
schema model {
  @desc("The LLM provider to use (e.g. openai, anthropic).")
  provider = string

  @desc("The model to use for this agent. (e.g. gpt-5.2, gemini-2.5-flash).")
  model_name = string

  @desc("The API key to use for this model.")
  api_key = string | null

  @desc("The base URL to use for this model.")
  base_url = string | null

  @desc("Sampling temperature between 0 and 1.")
  temperature = number | null
}

@suppress("duplicate-block")
@only_assignments
@workflow_node
schema tool {
  @desc("The description of the tool.")
  desc = string | null

  @desc("The input schema for the tool.")
  input_schema = schema | null

  @desc("The output schema for the tool.")
  output_schema = schema | null

  @desc("The callable to invoke for the tool.")
  invoke = callable
}

@suppress("duplicate-block")
@only_assignments
@workflow_node
schema agent {
  @desc("The model to use. Can be a reference to a model block or a string.")
  model = string | model

  @desc("The persona of the agent.")
  persona = string

  @desc("The tools to use for this agent.")
  tools = list[tool] | null

  @desc("Whether to use chain of thought for the agent.")
  chain_of_thought = bool | null

  @desc("The structured output schema for this agent.")
  output_schema = schema | null
}

@suppress("duplicate-block")
@only_assignments
schema knowledge {
  @desc("The description of the knowledge source.")
  desc = string | null
}

@suppress("duplicate-block")
@only_assignments
@workflow_node
@trigger_node
schema cron {
  @desc("Cron schedule expression (e.g. \"0 9 * * 1-5\").")
  schedule = string

  @desc("IANA timezone name (e.g. \"America/New_York\"). Defaults to UTC when unset.")
  timezone = string | null
}

@suppress("duplicate-block")
@only_assignments
@workflow_node
@trigger_node
schema webhook {
  @desc("URL path for this webhook (e.g. \"/hooks/job\").")
  path = string

  @desc("HTTP method (e.g. \"POST\").")
  method = string | null
}


@suppress("duplicate-block")
@only_assignments
@workflow_node
schema branch {
  @desc(```
  The transform to apply to the input.

  Example:
  workflow wf {
    some_agent -> branch {
      transform = \(out string) -> out.lower()
      route = {
        "route_1": agent_1,
        "route_2": agent_2,
      }
    }
  }
  ```)
  transform = callable | null

  // TODO: Remove the any here and it should be workflow_node
  // but workflow_node should be a schema and we should support
  // structural similarity instead of strict schema match.
  //
  // i.e.
  // schema_1 = schema { a = str b = bool c = number }
  // schema_2 = schema { a = str b = bool }
  // here schema_1 is compatible with schema_2 because it has
  // all the fields that schema_2 requires (we shouldn't care about c).
  //
  // The problem is that `schema bool {}` will match with all schema,
  // so we maybe introduce @strict_check annotation to enforce strict schema match.
  //
  // This is more or less duck typing. It can quack so it's a duck.
  @desc("The routes to take based on the input.")
  route = map[string | number | bool, any]
}

// The Type of `<expr> -> <expr>`
@suppress("duplicate-block")
@only_assignments
@workflow_node
schema workflow_chain {

  // FIXME: This should not be any and something like workflow_node.
  // And we should support structural similarity instead of strict schema match.
  // Read the comments of branch block above.

  @desc("The left side of the workflow chain.")
  left = any

  @desc("The right side of the workflow chain.")
  right = any
}
