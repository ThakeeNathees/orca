// A full example combining multiple block types.

model gpt4 {
  provider    = "openai"
  version     = "gpt-4o"
  temperature = 0.2
}

model claude {
  provider    = "anthropic"
  version     = "claude-sonnet-4-20250514"
  temperature = 0.3
}

tool web_search {
  invoke = "langchain_community.tools.web_search.WebSearchTool"
}

tool slack {
  desc   = "Send messages to Slack"
  invoke = "integrations.slack.send_message"
}

// The researcher uses web search to gather information.
agent researcher {
  model  = gpt4
  tools  = [web_search]
  prompt = "You research topics thoroughly and return structured findings."
}

// The writer turns research into reports.
agent writer {
  model  = claude
  prompt = "You are a technical writer."
}

agent reviewer {
  model  = gpt4
  prompt = "You review documents for accuracy and clarity."
}

